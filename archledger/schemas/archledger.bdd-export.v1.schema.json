{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archledger.dev/schemas/archledger.bdd-export.v1.schema.json",
  "title": "Archledger BDD export result",
  "type": "object",
  "required": ["schema", "record_id", "output_file", "warnings"],
  "properties": {
    "schema": { "const": "archledger.bdd-export.v1" },
    "record_id": { "type": "string" },
    "output_file": { "type": "string" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
