{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archledger.dev/schemas/archledger.bdd-export.v1.schema.json",
  "title": "Archledger BDD export result",
  "type": "object",
  "required": ["schema", "exported", "feature_files", "warnings"],
  "properties": {
    "schema": { "const": "archledger.bdd-export.v1" },
    "exported": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["record_id", "feature", "file"],
        "properties": {
          "record_id": { "type": "string" },
          "feature": { "type": "string" },
          "file": { "type": "string" }
        }
      }
    },
    "feature_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
