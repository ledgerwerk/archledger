{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archledger.dev/schemas/archledger.bdd-sync.v1.schema.json",
  "title": "Archledger BDD sync result",
  "type": "object",
  "required": ["schema", "checked", "feature_files_checked", "findings"],
  "properties": {
    "schema": { "const": "archledger.bdd-sync.v1" },
    "checked": { "type": "integer", "minimum": 0 },
    "feature_files_checked": { "type": "integer", "minimum": 0 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "type": "string" },
          "message": { "type": "string" },
          "record_id": { "type": "string" },
          "feature_file": { "type": "string" }
        }
      }
    }
  }
}
