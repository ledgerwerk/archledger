{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archledger.dev/schemas/archledger.sdd-check.v2.schema.json",
  "title": "Archledger SDD check result",
  "type": "object",
  "required": [
    "schema",
    "default_profile",
    "enabled_profiles",
    "sdd_enabled",
    "policy",
    "summary",
    "errors",
    "warnings"
  ],
  "properties": {
    "schema": { "const": "archledger.sdd-check.v2" },
    "default_profile": { "type": "string" },
    "enabled_profiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sdd_enabled": { "type": "boolean" },
    "policy": { "type": "object" },
    "summary": { "type": "object" },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "type": "string" },
          "message": { "type": "string" },
          "record_id": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "type": "string" },
          "message": { "type": "string" },
          "record_id": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    }
  }
}
