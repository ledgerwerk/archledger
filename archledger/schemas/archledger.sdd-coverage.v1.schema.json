{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Archledger SDD coverage",
  "type": "object",
  "required": [
    "schema",
    "sdd_enabled",
    "totals",
    "coverage",
    "gaps",
    "by_record"
  ],
  "properties": {
    "schema": { "const": "archledger.sdd-coverage.v1" },
    "sdd_enabled": { "type": "boolean" },
    "totals": { "type": "object" },
    "coverage": { "type": "object" },
    "gaps": { "type": "array", "items": { "type": "string" } },
    "by_record": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["record_id", "type", "status", "covered", "gaps"],
        "properties": {
          "record_id": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string" },
          "covered": { "type": "object" },
          "gaps": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
