{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archledger.dev/schemas/archledger.sdd-init.v1.schema.json",
  "title": "Archledger SDD init result",
  "type": "object",
  "required": [
    "schema",
    "dry_run",
    "steps",
    "policy_before",
    "policy",
    "seeded"
  ],
  "properties": {
    "schema": { "const": "archledger.sdd-init.v1" },
    "dry_run": { "type": "boolean" },
    "steps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "policy_before": { "type": "object" },
    "policy": { "type": "object" },
    "seeded": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "title"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "title": { "type": "string" }
        }
      }
    }
  }
}
