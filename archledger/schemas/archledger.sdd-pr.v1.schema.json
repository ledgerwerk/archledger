{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archledger.dev/schemas/archledger.sdd-pr.v1.schema.json",
  "title": "Archledger SDD PR check result",
  "description": "Combined payload from sdd check-pr: source-tracking changes plus SDD check results.",
  "type": "object",
  "required": ["schema", "against", "changes", "sdd"],
  "properties": {
    "schema": { "const": "archledger.sdd-pr.v1" },
    "against": {
      "type": "string",
      "description": "Git revision checked against."
    },
    "changes": {
      "description": "Source-tracking change-set payload (archledger.changed.v1)."
    },
    "sdd": { "$ref": "archledger.sdd.v1.schema.json" }
  }
}
