{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archledger.dev/schemas/archledger.sdd-status.v1.schema.json",
  "title": "Archledger SDD status result",
  "type": "object",
  "required": ["schema", "profile", "counts", "coverage"],
  "properties": {
    "schema": { "const": "archledger.sdd-status.v1" },
    "profile": { "type": "string" },
    "counts": { "$ref": "#/$defs/status_counts" },
    "coverage": { "$ref": "#/$defs/status_coverage" }
  },
  "$defs": {
    "status_counts": {
      "type": "object",
      "required": [
        "requirements",
        "accepted_requirements",
        "acceptance_criteria",
        "adrs",
        "quality_scenarios",
        "risks"
      ],
      "properties": {
        "requirements": { "type": "integer", "minimum": 0 },
        "accepted_requirements": { "type": "integer", "minimum": 0 },
        "acceptance_criteria": { "type": "integer", "minimum": 0 },
        "adrs": { "type": "integer", "minimum": 0 },
        "quality_scenarios": { "type": "integer", "minimum": 0 },
        "risks": { "type": "integer", "minimum": 0 }
      }
    },
    "status_coverage": {
      "type": "object",
      "required": [
        "accepted_requirements_with_ac",
        "accepted_requirements_with_implementation_refs",
        "accepted_requirements_with_validation",
        "accepted_adrs_with_traceability"
      ],
      "properties": {
        "accepted_requirements_with_ac": { "type": "integer", "minimum": 0 },
        "accepted_requirements_with_implementation_refs": {
          "type": "integer",
          "minimum": 0
        },
        "accepted_requirements_with_validation": {
          "type": "integer",
          "minimum": 0
        },
        "accepted_adrs_with_traceability": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
