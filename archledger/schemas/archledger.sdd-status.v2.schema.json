{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Archledger SDD status v2",
  "type": "object",
  "required": [
    "schema",
    "default_profile",
    "enabled_profiles",
    "sdd_enabled",
    "policy",
    "counts",
    "coverage"
  ],
  "properties": {
    "schema": { "const": "archledger.sdd-status.v2" },
    "default_profile": { "type": "string" },
    "enabled_profiles": { "type": "array", "items": { "type": "string" } },
    "sdd_enabled": { "type": "boolean" },
    "policy": { "type": "object" },
    "counts": { "type": "object" },
    "coverage": { "type": "object" }
  }
}
