{#- Shared front matter for all record templates. -#}
{#- Required variables: id, title, status, section, order, version, body_format -#}
{#- Optional variable: type (defaults to record kind) -#}
---
schema_version: {{ schema_version | default(4, true) }}
id: {{ id }}
kind: {{ kind }}
type: {{ type }}
title: {{ title | tojson }}
status: {{ status }}
section: {{ section }}
order: {{ order }}
version: {{ version | default(1, true) }}
applies_to: []
body_format: {{ body_format }}
---
