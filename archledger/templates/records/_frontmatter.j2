{#- Shared front matter for all record templates. -#}
{#- Required variables: id, title, status, section, order, date, body_format, created_at, updated_at -#}
{#- Optional variable: type (defaults to record kind) -#}
---
schema_version: {{ schema_version | default(2, true) }}
id: {{ id }}
kind: {{ kind }}
type: {{ type }}
title: {{ title | tojson }}
status: {{ status }}
section: {{ section }}
order: {{ order }}
date: {{ date | tojson }}
applies_to: []
body_format: {{ body_format }}
created_at: {{ created_at | tojson }}
updated_at: {{ updated_at | tojson }}
---
