---
schema_version: {{ schema_version | default(3, true) }}
id: {{ id }}
kind: {{ kind }}
type: diagram
title: {{ title | tojson }}
status: {{ status }}
section: {{ section }}
order: {{ order }}
date: {{ date | tojson }}
diagram_type: {{ diagram_type | tojson }}
caption: {{ caption | tojson }}
{% if related_records %}
related_records:
{% for record_id in related_records %}
  - {{ record_id | tojson }}
{% endfor %}
{% else %}
related_records: []
{% endif %}
tags: []
body_format: asciidoc
created_at: {{ created_at | tojson }}
updated_at: {{ updated_at | tojson }}
---

{% if diagram_type == "mermaid" %}
[mermaid]
....
flowchart LR
  A[Start] --> B[Describe architecture flow]
....
{% elif diagram_type == "svgbob" %}
[svgbob]
....
+---------+     +----------+
| Source  | --> | Output   |
+---------+     +----------+
....
{% else %}
[source,text]
----
┌─────────┐     ┌──────────┐
│ Source  │ ──> │ Output   │
└─────────┘     └──────────┘
----
{% endif %}
