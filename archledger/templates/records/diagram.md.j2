---
schema_version: {{ schema_version | default(4, true) }}
id: {{ id }}
kind: {{ kind }}
type: diagram
title: {{ title | tojson }}
status: {{ status }}
section: {{ section }}
order: {{ order }}
version: {{ version | default(1, true) }}
diagram_type: {{ diagram_type | tojson }}
caption: {{ caption | tojson }}
{% if related_records %}
related_records:
{% for record_id in related_records %}
  - {{ record_id | tojson }}
{% endfor %}
{% else %}
related_records: []
{% endif %}
tags: []
body_format: markdown
---

{% if diagram_type == "mermaid" %}
```mermaid
flowchart LR
  A[Start] --> B[Describe architecture flow]
```
{% elif diagram_type == "svgbob" %}
```svgbob
+---------+     +----------+
| Source  | --> | Output   |
+---------+     +----------+
```
{% else %}
```textdiagram
┌─────────┐     ┌──────────┐
│ Source  │ ──> │ Output   │
└─────────┘     └──────────┘
```
{% endif %}
